# SQLite (для запуска без PostgreSQL)
DATABASE_URL="file:./dev.db"
# Или PostgreSQL (локально):
# DATABASE_URL="postgresql://user:password@localhost:5432/kelajak?schema=public"
# На Vercel (Neon/Supabase и др.): добавьте в конец URL параметр pgbouncer=true,
# иначе возможна ошибка "prepared statement already exists" (42P05):
# DATABASE_URL="postgresql://...?sslmode=require&pgbouncer=true"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
